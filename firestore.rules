rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userRole() == "admin";
    }

    function ownsEvent(eventId) {
      return signedIn()
        && exists(/databases/$(database)/documents/events/$(eventId))
        && get(/databases/$(database)/documents/events/$(eventId)).data.clientUid == request.auth.uid;
    }

    function activeEvent(eventId) {
      return exists(/databases/$(database)/documents/events/$(eventId))
        && get(/databases/$(database)/documents/events/$(eventId)).data.active == true;
    }

    match /users/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow create, update, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /uploads/{uploadId} {
      allow read: if isAdmin() || ownsEvent(resource.data.eventCode) || activeEvent(resource.data.eventCode);
      allow create: if request.resource.data.eventCode is string
        && activeEvent(request.resource.data.eventCode);
      allow update, delete: if isAdmin();
    }
  }
}
