rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function validGuestUpload() {
      return request.resource.size < 100 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*')
        && firestore.exists(/databases/(default)/documents/events/$(eventCode))
        && firestore.get(/databases/(default)/documents/events/$(eventCode)).data.active == true;
    }

    match /events/{eventCode}/uploads/{fileName} {
      allow read: if signedIn();
      allow write: if validGuestUpload();
    }
  }
}
