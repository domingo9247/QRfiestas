rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function validGuestUpload() {
      return request.resource.size < 100 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*');
    }

    match /events/{eventCode}/uploads/{fileName} {
      allow read: if true;
      allow write: if validGuestUpload();
    }
  }
}
